{
  "name": "scamshield-ai",
  "private": true,
  "version": "0.1.1",
  "description": "ScamShield AI — Anna App fraud investigation workbench.",
  "type": "module",
  "scripts": {
    "dev": "anna-app dev --port 5184 --no-llm",
    "dev:llm": "anna-app dev --port 5184 --llm-account https://anna.partners",
    "validate": "anna-app validate --strict",
    "fixture:verify": "anna-app fixture verify fixtures/happy-path.jsonl",
    "test": "vitest run tests/bundle && npm run test:plugin",
    "test:plugin": "python -m unittest discover -s tests/plugin",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run validate && npm run test:e2e"
  },
  "devDependencies": {
    "@anna-ai/cli": "^0.1.22",
    "@playwright/test": "^1.54.1",
    "http-server": "^14.1.1",
    "vitest": "^2.1.0"
  }
}
